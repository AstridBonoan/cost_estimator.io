# ============================================================================
# Cost Estimator Payment Backend - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git - add it to .gitignore
#
# Get your Stripe keys from: https://dashboard.stripe.com/apikeys
# ============================================================================

# --- STRIPE CONFIGURATION ---
# Test keys (start with sk_test_) for development
# Live keys (start with sk_live_) for production
STRIPE_SECRET_KEY=sk_test_your_secret_key_here_replace_me

# Webhook signing secret (optional but recommended)
# Get from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_test_your_webhook_secret_here_replace_me

# --- SERVER CONFIGURATION ---
# Port your backend runs on
PORT=3001

# Environment: development or production
NODE_ENV=development

# --- CORS CONFIGURATION ---
# Your estimator website domain
# Development: http://localhost:3000
# Production: https://estimator.tamayenterprises.com
CORS_ORIGIN=http://localhost:3000

# ============================================================================
# SETUP INSTRUCTIONS:
# ============================================================================
# 
# 1. Get Stripe Keys:
#    - Visit https://dashboard.stripe.com/apikeys
#    - Copy your Secret Key (starts with sk_test_ or sk_live_)
#    - Paste into STRIPE_SECRET_KEY above
#
# 2. Setup Webhook (Optional but recommended):
#    - Visit https://dashboard.stripe.com/webhooks
#    - Click "Add endpoint"
#    - Enter: https://your-server.com/webhook
#    - Select events: payment_intent.succeeded, payment_intent.payment_failed
#    - Copy the signing secret
#    - Paste into STRIPE_WEBHOOK_SECRET above
#
# 3. Configure CORS:
#    - Set CORS_ORIGIN to where your estimator is hosted
#    - For local testing use: http://localhost:3000
#    - For production use: https://your-domain.com
#
# 4. Start Server:
#    - npm install
#    - node server.js
#
# ============================================================================
# TESTING CREDENTIALS:
# ============================================================================
# 
# Stripe Test Cards:
#   Success:       4242 4242 4242 4242
#   Requires Auth: 4000 0027 6000 3184
#   Declined:      4000 0000 0000 0002
#   Amex:          3782 822463 10005
#
# Expiry: Any future date (e.g., 12/25)
# CVC: Any 3 digits
#
# ============================================================================
# ENVIRONMENT TRANSITION:
# ============================================================================
#
# Development to Production Checklist:
# [ ] Update STRIPE_SECRET_KEY to live key (sk_live_...)
# [ ] Update NODE_ENV to production
# [ ] Update CORS_ORIGIN to production domain
# [ ] Enable HTTPS on frontend
# [ ] Setup Webhook with production URL
# [ ] Test payment with small real amount first
# [ ] Monitor Stripe dashboard for payments
#
# ============================================================================
